# Example env file for Boss Listers MVP

# Base URL of the app (used on frontend if needed)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Directory (under public/) where uploaded images are stored
UPLOADS_DIR=uploads

# Optional absolute directory for JSON history storage in production
DATA_DIR=

# Server-side OpenAI API key used for image recognition
OPENAI_API_KEY=

# Optional override for the vision-capable model
OPENAI_VISION_MODEL=gpt-4o-mini
